<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <p>Description: <%= service_project.description %></p>
    <p>Date: <%= service_project.project_date %></p>
    <p>Location: <%= service_project.location %></p>
    <p>Organization: 
        <a href="/organization/<%= service_project.organization_id %>">
            <%= service_project.organization_name %>
        </a>
    </p>

    <ul>
        <% projectCategories.forEach(category => { %>
            <li>
                project Category: <a href="/category/<%= category.project_id %>"><%= category.category_name %></a>
            </li>
        <% }); %>
    </ul>
   
</main>

<%- include('partials/footer') %>